#!/bin/bash

packages=(
    bat
    btop
    cloc
    copyq
    curl
    delve
    docker
    docker-compose
    duf
    eza
    fastfetch
    fd
    ffmpeg
    fish
    fzf
    ghostty
    git
    github-cli
    glow
    go
    go-task
    gopls
    goreleaser
    gnome-tweaks
    hyperfine
    jq
    lldb
    llvm
    mpv
    neovim
    nodejs
    npm
    ripgrep
    rust-analyzer
    rustup
    stow
    strace
    tmux
    transmission-cli
    transmission-gtk
    wget
    xclip
    zig
    zls
    zoxide
)

for package in "${packages[@]}"; do
    sudo pacman -S --needed "$package"
done

git clone https://github.com/ifdiego/dotfiles.git ~/dotfiles
stow -d ~/dotfiles -t ~ .

chsh -s "$(which fish)"
curl -sL https://git.io/fisher | source
fisher update

sudo systemctl start docker.service
sudo systemctl enable docker.service
sudo usermod -aG docker "$USER"

chmod 700 ~/.ssh
curl https://github.com/ifdiego.keys -o ~/.ssh/id_ed25519.pub
ssh-add ~/.ssh/id_ed25519
ssh -T git@github.com

gh auth login
gh repo list --json owner,name --jq '.[] | select(.name != "dotfiles") | "\(.owner.login)/\(.name)"' |
while IFS= read -r repo; do
    git clone "git@github.com:$repo.git" ~/"${repo#*/}"
done

rustup default stable

gsettings set org.gnome.desktop.input-sources xkb-options "['ctrl:nocaps']"
gsettings set org.gnome.desktop.peripherals.keyboard delay 200
gsettings set org.gnome.desktop.peripherals.keyboard repeat-interval 10

git clone https://aur.archlinux.org/yay-bin.git
cd yay-bin
makepkg -si
yay -S brave-bin

git -C ~/dotfiles remote set-url origin git@github.com:ifdiego/dotfiles.git
