[user]
	name = Diego Alves
	email = ifdiego@users.noreply.github.com
	signingKey = ~/.ssh/id_ed25519.pub
[core]
	editor = nvim
[commit]
	gpgSign = true
[init]
	defaultBranch = main
[gpg]
	format = ssh
[push]
	autoSetupRemote = true
[alias]
	br = branch
	ci = commit
	co = checkout
	dc = diff --cached
	ec = config --global -e
	lg = log --oneline --graph
	st = status
	authors = !git log --format='%an <%ae>' | sort -u
