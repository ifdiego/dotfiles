xterm*faceName: xft: Droid Sans Mono
xterm*faceSize: 12
xterm*saveLines: 2000
xterm*foreground: white
xterm*background: #1e1e1e
xterm*color4: cornflowerblue
xterm*selectToClipboard: true
xterm*VT100.Translations: #override \
  Shift <Btn1Up>: select-end(PRIMARY, CLIPBOARD, CUT_BUFFER0) \n\
  Ctrl <KeyPress> V: insert-selection(CLIPBOARD, CUT_BUFFER0, PRIMARY)
